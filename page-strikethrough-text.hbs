et="_blank">Memory Challenge - 7.5M combinations in 12 clicks</a></p><br><br></body><script>var input = document.getElementById('input'), lower = document.getElementById('strikethrough');function update(){ lower.value = strikeme(input.value);}input.addEventListener('blur',update);input.addEventListener('keyup',update);function strikeme(text) { var result = ""; for (var i = 0; i < text.length; i++) { result += "\u0336" + text.charAt(i); }; return result;}</script></html>