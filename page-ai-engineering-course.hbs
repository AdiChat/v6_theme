{{!< default}}
{{!-- Custom page template. Create a Ghost Page with slug "ai-engineering-course".
    Replace the three LEMONSQUEEZY_* placeholder links once Lemon Squeezy is approved. --}}

<style>
.ogc{
  --ink:#1d1d1f;
  --ink2:#6e6e73;
  --hair:#e3e6ea;
  --surf:#f5f5f7;
  --acc:#3eb0ef;
  color:var(--ink);
  line-height:1.6;
  font-family:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Arial,sans-serif;
}

.ogc a{
  color:var(--acc);
  text-decoration:none;
}

.ogc .wrap{
  max-width:1000px;
  margin:0 auto;
  padding:0 24px;
}

.ogc .hero{
  background:#1d1d1f;
  color:#fff;
  text-align:center;
  padding:70px 24px 58px;
}

.ogc .badge{
  display:inline-block;
  background:rgba(255,255,255,.14);
  border:1px solid rgba(255,255,255,.28);
  padding:5px 15px;
  border-radius:980px;
  font-size:13px;
  font-weight:600;
  letter-spacing:.06em;
  text-transform:uppercase;
  margin-bottom:22px;
}

.ogc .hero h1{
  font-size:clamp(32px,6vw,56px);
  line-height:1.08;
  letter-spacing:-.02em;
  font-weight:700;
  margin:0 auto 14px;
  max-width:20ch;
}

.ogc .hero .sub{
  color:#c7c9cc;
  font-size:clamp(16px,2.4vw,20px);
  max-width:60ch;
  margin:0 auto 12px;
}

.ogc .hero .start{
  color:#8fd0f5;
  font-weight:600;
  font-size:15px;
  margin:0 0 26px;
}

.ogc .hero .updated{
  color:#8a8d91;
  font-size:13px;
  margin-top:14px;
}

.ogc .cta{
  display:inline-block;
  background:var(--acc);
  color:#fff;
  font-weight:600;
  font-size:17px;
  padding:13px 28px;
  border-radius:10px;
}

.ogc .trust{
  margin-top:30px;
  color:#a9acb0;
  font-size:14px;
  display:flex;
  gap:8px 20px;
  justify-content:center;
  flex-wrap:wrap;
}

.ogc section{
  padding:56px 0;
}

.ogc h2{
  text-align:center;
  font-size:clamp(24px,3.4vw,34px);
  letter-spacing:-.02em;
  margin:0 0 10px;
}

.ogc .lead{
  text-align:center;
  color:var(--ink2);
  max-width:64ch;
  margin:0 auto 34px;
}

.ogc .cards{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:20px;
}

.ogc .card{
  border:1px solid var(--hair);
  border-radius:14px;
  padding:22px;
}

.ogc .card .ico{
  width:44px;
  height:44px;
  border-radius:12px;
  background:#eaf6fe;
  display:flex;
  align-items:center;
  justify-content:center;
  margin-bottom:12px;
}

.ogc .card h3{
  margin:0 0 6px;
  font-size:17px;
}

.ogc .card p{
  margin:0;
  color:var(--ink2);
  font-size:14px;
}

.ogc .incl{
  max-width:700px;
  margin:0 auto;
  padding:0;
}

.ogc .incl li{
  list-style:none;
  padding:9px 0 9px 34px;
  position:relative;
}

.ogc .incl li:before{
  content:"\2713";
  position:absolute;
  left:0;
  top:9px;
  color:var(--acc);
  font-weight:700;
}

.ogc .price{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:20px;
  align-items:start;
}

.ogc .tier{
  border:1px solid var(--hair);
  border-radius:16px;
  padding:26px;
  position:relative;
}

.ogc .tier.best{
  border-color:var(--acc);
  box-shadow:0 6px 24px rgba(62,176,239,.12);
}

.ogc .tier .flag{
  position:absolute;
  top:-12px;
  right:18px;
  background:var(--acc);
  color:#fff;
  font-size:12px;
  font-weight:700;
  padding:3px 10px;
  border-radius:980px;
}

.ogc .tier .flag.top{
  background:#1d1d1f;
}

.ogc .tier .was{
  color:var(--ink2);
  text-decoration:line-through;
  font-weight:500;
  font-size:16px;
  margin-right:8px;
}

.ogc .tier h3{
  margin:0 0 4px;
  font-size:19px;
}

.ogc .tier .amt{
  font-size:30px;
  font-weight:800;
  letter-spacing:-.02em;
  margin:6px 0 10px;
}

.ogc .tier .amt small{
  font-size:14px;
  color:var(--ink2);
  font-weight:500;
}

.ogc .tier ul{
  padding:0;
  margin:0;
}

.ogc .tier li{
  list-style:none;
  padding:6px 0 6px 24px;
  position:relative;
  font-size:14px;
}

.ogc .tier li:before{
  content:"\2713";
  position:absolute;
  left:0;
  color:var(--acc);
  font-weight:700;
}

.ogc .tier .cta{
  display:block;
  text-align:center;
  margin-top:18px;
  font-size:15px;
  padding:11px 18px;
}

.ogc .steps{
  display:grid;
  grid-template-columns:repeat(5,1fr);
  gap:14px;
}

.ogc .step .num{
  width:32px;
  height:32px;
  border-radius:50%;
  background:#eaf6fe;
  color:var(--acc);
  font-weight:700;
  display:flex;
  align-items:center;
  justify-content:center; margin-bottom:10px; }
.ogc .step h3{ margin:0 0 3px; font-size:15px; }
.ogc .step p{ margin:0; color:var(--ink2); font-size:13px; }
.ogc .fin{ text-align:center; color:var(--ink2); font-size:13px; margin-top:22px; }
@media (max-width:820px){
  .ogc .cards,
  .ogc .price{ grid-template-columns:1fr; }
  .ogc .steps{ grid-template-columns:1fr 1fr; }
}
</style>

