}
@media (max-width: 900px) {
  .second-left {
    z-index: 99;
  }
  .left-side-bar-top {
    margin-bottom: 0;
  }
  .main-posts.fix-bottom .left-side-bar,
  .main-posts.fix-top .left-side-bar {
    position: fixed;
    top: 38px;
  }
