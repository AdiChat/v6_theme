    position: relative;
  }
}

@media (max-width: 600px) {
  .second-left {
    z-index: 99;
  }
  .left-side-bar-top {
    margin-bottom: 0;
  }
  .left-side-bar-wrapper {
    display: none;
  }
}

.left-side-bar,
.top-side-bar-links {
